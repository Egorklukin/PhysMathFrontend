<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainScreenFragment">
    <fragment
        android:id="@+id/mainScreenFragment"
        android:name="com.example.physmath.ui.main.MainScreenFragment"
        android:label="PhysMath"
        tools:layout="@layout/fragment_main_screen">

        <action
            android:id="@+id/actionMainScreenToTopicListFragment"
            app:destination="@id/topicListFragment" />
    </fragment>

    <fragment
        android:id="@+id/topicListFragment"
        android:name="com.example.physmath.ui.topics.TopicListFragment"
        android:label="Темы"
        tools:layout="@layout/fragment_topic_list">

        <argument
            android:name="subjectId"
            app:argType="string"
            app:nullable="false" />
        <argument
            android:name="subjectTitle"
            app:argType="string"
            app:nullable="false" />

        <action
            android:id="@+id/actionTopicListToLessonListFragment"
            app:destination="@id/lessonsFragment" />
    </fragment>

    <fragment
        android:id="@+id/lessonsFragment"
        android:name="com.example.physmath.ui.lessons.LessonsFragment"
        android:label="Конспекты"
        tools:layout="@layout/fragment_lessons">

        <argument android:name="topicId" app:argType="string" app:nullable="true" android:defaultValue="@null"/>
        <argument android:name="topicTitle" app:argType="string" app:nullable="true" android:defaultValue="@null"/>
        <argument android:name="subjectId" app:argType="string" app:nullable="true" android:defaultValue="@null"/>

        <action
            android:id="@+id/action_lessonsFragment_to_lessonDetailFragment"
            app:destination="@id/lessonDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/lessonDetailFragment"
        android:name="com.example.physmath.ui.lessons.LessonDetailFragment"
        android:label="Урок"
        tools:layout="@layout/fragment_lesson_detail">

        <argument android:name="lessonId" app:argType="string" app:nullable="false" />

        <action
            android:id="@+id/action_lessonDetailFragment_to_testsRunFragment"
            app:destination="@id/testsRunFragment" />
    </fragment>

    <fragment
        android:id="@+id/testsListFragment"
        android:name="com.example.physmath.ui.tests.TestsListFragment"
        android:label="Тесты"
        tools:layout="@layout/fragment_tests_list">

        <action
            android:id="@+id/action_testsListFragment_to_testsRunFragment"
            app:destination="@id/testsRunFragment">
            <argument android:name="lessonId" app:argType="string" app:nullable="false" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/testsRunFragment"
        android:name="com.example.physmath.ui.tests.TestsRunFragment"
        android:label="Пройти тест"
        tools:layout="@layout/fragment_tests">

        <argument android:name="lessonId" app:argType="string" app:nullable="false" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.physmath.ui.settings.SettingsFragment"
        android:label="Настройки"
        tools:layout="@layout/fragment_settings">

        <action
            android:id="@+id/action_settingsFragment_to_feedbackFragment"
            app:destination="@id/feedbackFragment" />
    </fragment>

    <fragment
        android:id="@+id/feedbackFragment"
        android:name="com.example.physmath.ui.feedback.FeedbackFragment"
        android:label="Предложить идею"
        tools:layout="@layout/fragment_feedback" />

</navigation>
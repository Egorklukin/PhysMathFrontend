<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_background"
        app:navigationIconTint="@color/color_accent"
        app:title="⚙️ Настройки"
        app:titleTextColor="@color/color_text_main"
        app:contentInsetStartWithNavigation="0dp"
        app:contentInsetEndWithActions="0dp"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/btn_theme_system"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Как в системе"
                android:src="@drawable/ic_theme_auto"
                android:scaleType="centerInside"/>

            <ImageButton
                android:id="@+id/btn_theme_light"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Светлая тема"
                android:src="@drawable/ic_theme_light"
                android:scaleType="centerInside"/>

            <ImageButton
                android:id="@+id/btn_theme_dark"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Тёмная тема"
                android:src="@drawable/ic_theme_dark"
                android:scaleType="centerInside"/>
        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/color_text_hint"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📦 Данные приложения"
                        android:textColor="@color/color_text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Экспорт или импорт прогресса между устройствами."
                        android:textColor="@color/color_text_sub"
                        android:textSize="13sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_export"
                        style="@style/Widget.PhysMath.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📤 Экспорт прогресса"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_import"
                        style="@style/Widget.PhysMath.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📥 Импорт прогресса"
                        android:textColor="@color/color_accent"
                        app:strokeColor="@color/color_accent"
                        android:fontFamily="@font/jetbrains_mono"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_feedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/color_text_hint"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 Обратная связь"
                        android:textColor="@color/color_text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Предложите урок или сообщите об ошибке."
                        android:textColor="@color/color_text_sub"
                        android:textSize="13sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_feedback"
                        style="@style/Widget.PhysMath.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✉️ Написать разработчикам"
                        android:fontFamily="@font/jetbrains_mono"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_offline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/color_accent"
                app:strokeWidth="2dp"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📦 Офлайн-доступ"
                        android:textColor="@color/color_text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Загрузите все уроки для работы без интернета."
                        android:textColor="@color/color_text_sub"
                        android:textSize="13sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginBottom="12dp"/>
                    <ProgressBar
                        android:id="@+id/pb_download"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginBottom="8dp"
                        android:progressTint="@color/color_accent"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tv_download_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_sub"
                        android:textSize="12sp"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_download_all"
                        style="@style/Widget.PhysMath.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📥 Загрузить всё для офлайн"
                        android:fontFamily="@font/jetbrains_mono"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_delete_all"
                        style="@style/Widget.PhysMath.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🗑️ Очистить кэш"
                        android:textColor="@color/color_error"
                        app:strokeColor="@color/color_error"
                        android:fontFamily="@font/jetbrains_mono"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

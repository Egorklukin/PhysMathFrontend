<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_background"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/color_accent"
        app:titleTextColor="@color/color_text_main"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 Предложить урок или тест"
                android:textColor="@color/color_text_main"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/jetbrains_mono"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Помогите нам сделать приложение лучше — расскажите, чего не хватает"
                android:textColor="@color/color_text_sub"
                android:textSize="14sp"
                android:fontFamily="@font/jetbrains_mono"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Что вы хотите предложить?"
                android:textColor="@color/color_text_main"
                android:textSize="14sp"
                android:fontFamily="@font/jetbrains_mono"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rg_request_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rb_lesson"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📚 Урок"
                    android:checked="true"
                    android:textColor="@color/color_text_main"
                    android:fontFamily="@font/jetbrains_mono"/>

                <RadioButton
                    android:id="@+id/rb_test"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🧪 Тест"
                    android:textColor="@color/color_text_main"
                    android:fontFamily="@font/jetbrains_mono"/>
            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Тема *"
                android:textColorHint="@color/text_hint"
                app:boxStrokeColor="@color/color_accent"
                app:hintTextColor="@color/color_accent"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_topic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:fontFamily="@font/jetbrains_mono"
                    android:textColor="@color/color_text_main"
                    android:textColorHint="@color/color_text_hint"
                    android:maxLength="100"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Подробности (необязательно)"
                android:textColorHint="@color/text_hint"
                app:boxStrokeColor="@color/color_accent"
                app:hintTextColor="@color/color_accent"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:lines="4"
                    android:gravity="top|start"
                    android:fontFamily="@font/jetbrains_mono"
                    android:textColor="@color/color_text_main"
                    android:maxLength="500"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email для связи (необязательно)"
                android:textColorHint="@color/text_hint"
                app:boxStrokeColor="@color/color_accent"
                app:hintTextColor="@color/color_accent"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:fontFamily="@font/jetbrains_mono"
                    android:textColor="@color/color_text_main"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                style="@style/Widget.PhysMath.Button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✉️ Отправить пожелание"
                android:fontFamily="@font/jetbrains_mono"/>

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>